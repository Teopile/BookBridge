# --- Server runtime ---
PORT=3001
NODE_ENV=development
PUBLIC_FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_ADMIN_ORIGIN=http://localhost:5174

# --- Supabase (required) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SECRET_KEY=eyJ...

# --- Security ---
CSRF_SECRET=change-me-to-a-long-random-string-min-32-chars
COOKIE_SECRET=change-me-to-another-long-random-string-32-chars

# --- Email (Maileroo) ---
MAILEROO_API_KEY=
MAILEROO_FROM=noreply@yourdomain.ge
MAILEROO_FROM_NAME=BookBridge

# --- Payments (Flitt) ---
PAYMENT_PROVIDER=disabled
FLITT_MERCHANT_ID=
FLITT_PAYMENT_KEY=
FLITT_CREDIT_PRIVATE_KEY=
FLITT_WEBHOOK_SECRET=

# --- Courier API ---
COURIER_PROVIDER=manual
COURIER_API_KEY=
COURIER_WEBHOOK_SECRET=

# --- Observability ---
SENTRY_DSN_SERVER=
# Optional: if set, the global error handler POSTs uncaught request errors
# (JSON: message/status/stack/method/path/ts) to this URL. Leave empty to disable.
ERROR_WEBHOOK=

# --- Misc ---
RATE_LIMIT_PER_MIN=120
